# Data — never commit medical images or PHI-adjacent files.
# Leading slash anchors to the repo root, so this ignores the top-level
# data/ download folder but NOT the mammoval/data/ source package.
/data/
*.dcm
*.DICOM

# Model weights
*.pth
*.pt
*.ckpt
*.onnx
/weights/

# Pipeline outputs (generated reports land here; a curated copy of the
# real report is committed under docs/ deliberately).
/outputs/
/reports/

# Credentials
kaggle.json
.kaggle/
*.pem

# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/
/build/
/dist/
.venv/
venv/
